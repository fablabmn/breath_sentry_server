    {
        "id": "3ce2484a6ec88c23",
        "type": "function",
        "z": "a37c0a24890d4767",
        "name": "query",
        "func": "const board_id = msg.req.query.board_id;\n\nif (!board_id) {\n    msg.statusCode = 400;\n    msg.payload = { error: \"board_id is required\" };\n    return [null, msg];\n}\n\nnode.warn(\"Board ID \"+ board_id);\n\nmsg.query = `\nfrom(bucket: \"sentry_bucket\")\n  |> range(start: -7d)\n  |> filter(fn: (r) => r._measurement == \"air_quality\")\n  |> filter(fn: (r) => r.board_id == \"${board_id}\")\n`;\nnode.warn(msg);\nreturn [msg, null];",
        "outputs": 2,
        "timeout": 0,
        "noerr": 0,
        "initialize": "",
        "finalize": "",
        "libs": [],
        "x": 450,
        "y": 360,
        "wires": [
