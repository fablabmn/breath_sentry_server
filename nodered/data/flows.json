    {
        "id": "61c1737f429fd039",
        "type": "function",
        "z": "a37c0a24890d4767",
        "name": "json_reformatter",
        "func": "const result = msg.payload;\n\nif (!result || result.length === 0) {\n    msg.statusCode = 404;\n    msg.payload = { error: \"No data found\" };\n    return msg;\n}\n\n// Raggruppa per timestamp\nconst grouped = {};\nresult.forEach(row => {\n    const ts = row._time;\n    if (!grouped[ts]) {\n        grouped[ts] = { timestamp: ts, board_id: row.board_id };\n    }\n    grouped[ts][row._field] = row._value;\n});\n\nmsg.statusCode = 200;\nmsg.headers = { \"Content-Type\": \"application/json\" };\nmsg.payload = Object.values(grouped);\n\nreturn msg;",
        "outputs": 1,
        "timeout": 0,
        "noerr": 0,
        "initialize": "",
        "finalize": "",
        "libs": [],
        "x": 780,
        "y": 440,
        "wires": [
