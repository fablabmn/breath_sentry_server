    {
        "id": "c373295522002c8f",
        "type": "function",
        "z": "b590023ad60e02f5",
        "name": "check_if_board_is_authorized",
        "func": "const msg_board_id = flow.get('msg_board_id') || '';\nconst global_board_msg = JSON.parse(flow.get('global_board_msg')) || '';\nif (!msg_board_id || !global_board_msg)\n{\n    node.warn(\"msg_board_id is null\");\n    return null;\n}\nfor (const it of msg.payload) \n{\n    if (it.board_id === msg_board_id && it.authorized) \n    {\n        return global_board_msg;\n    }\n}\nnode.warn(\"board_id: \" + msg_board_id + \" not found\");\nreturn null;",
        "outputs": 1,
        "timeout": 0,
        "noerr": 0,
